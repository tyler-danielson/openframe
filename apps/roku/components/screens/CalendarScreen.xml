<?xml version="1.0" encoding="utf-8" ?>
<component name="CalendarScreen" extends="Group">
    <interface>
        <field id="calendarData" type="assocarray" alwaysNotify="true" onChange="onDataChanged" />
    </interface>
    <script type="text/brightscript" uri="CalendarScreen.brs" />
    <children>
        <Rectangle width="1920" height="1080" color="0x0f172aFF">

            <Label
                id="dateLabel"
                text=""
                font="font:LargeBoldSystemFont"
                color="0x60a5faFF"
                width="1720"
                translation="[100, 80]" />

            <Label
                id="summaryLabel"
                text=""
                font="font:MediumSystemFont"
                color="0x94a3b8FF"
                width="1720"
                translation="[100, 150]" />

            <LayoutGroup
                id="eventsList"
                layoutDirection="vert"
                translation="[100, 230]"
                itemSpacings="[15]" />

            <Label
                id="emptyLabel"
                text="Your calendar is clear today"
                font="font:LargeBoldSystemFont"
                color="0x475569FF"
                horizAlign="center"
                vertAlign="center"
                width="1920"
                height="1080"
                visible="false" />
        </Rectangle>
    </children>
</component>
