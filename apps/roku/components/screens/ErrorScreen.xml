<?xml version="1.0" encoding="utf-8" ?>
<component name="ErrorScreen" extends="Group">
    <interface>
        <field id="errorMessage" type="string" value="" onChange="onErrorChanged" />
        <field id="retryRequested" type="boolean" alwaysNotify="true" value="false" />
        <field id="settingsRequested" type="boolean" alwaysNotify="true" value="false" />
    </interface>
    <script type="text/brightscript" uri="ErrorScreen.brs" />
    <children>
        <Rectangle width="1920" height="1080" color="0x0f172aFF">

            <LayoutGroup
                id="mainLayout"
                layoutDirection="vert"
                horizAlignment="center"
                vertAlignment="center"
                translation="[960, 300]"
                itemSpacings="[25]">

                <Label
                    id="iconLabel"
                    text="Connection Error"
                    font="font:LargeBoldSystemFont"
                    color="0xef4444FF"
                    horizAlign="center"
                    width="800" />

                <Label
                    id="messageLabel"
                    text="Cannot connect to server"
                    font="font:MediumSystemFont"
                    color="0x94a3b8FF"
                    horizAlign="center"
                    width="800"
                    maxLines="3"
                    wrap="true" />

                <Label
                    id="retryLabel"
                    text=""
                    font="font:SmallSystemFont"
                    color="0x64748bFF"
                    horizAlign="center"
                    width="800" />
            </LayoutGroup>

            <ButtonGroup
                id="buttonGroup"
                translation="[660, 650]"
                buttons="[Retry Now, Change Server, Exit]" />
        </Rectangle>

        <Timer id="retryTimer" repeat="false" />
    </children>
</component>
