<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background">#0A0A0A</color>
    <color name="border">#27272A</color>
    <color name="card">#18181B</color>
    <color name="primary">#3B82F6</color>
    <color name="primary_dark">#2563EB</color>
    <color name="qr_white">#FFFFFF</color>
    <color name="success">#22C55E</color>
    <color name="text_hint">#71717A</color>
    <color name="text_primary">#FAFAFA</color>
    <color name="text_secondary">#A1A1AA</color>
    <color name="warning">#EAB308</color>
    <string name="app_name">OpenFrame</string>
    <style name="Theme.OpenFrameCreateBoard" parent="Theme.AppCompat.NoActionBar">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_dark</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    <style name="Theme.OpenFrameCreateBoard.Fullscreen" parent="Theme.OpenFrameCreateBoard">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>